rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /admin_access/{adminId} {
      allow get: if isValidId(adminId);
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /admins/{adminUid} {
      allow get: if isOwner(adminUid);
      allow create: if isOwner(adminUid) && 
                      request.resource.data.keys().hasAll(['email', 'role', 'createdAt']) &&
                      request.resource.data.keys().size() == 3 &&
                      (request.resource.data.role == 'superadmin' || request.resource.data.role == 'admin') &&
                      request.resource.data.createdAt == request.time;
      allow list: if true;
    }

    match /applications/{applicationId} {
      allow create: if request.resource.data.keys().hasAll(['fullName', 'roll', 'regNo', 'department', 'semester', 'shift', 'group', 'status', 'createdAt']) &&
                      request.resource.data.status == 'pending' &&
                      request.resource.data.createdAt == request.time; 
      allow get, update, delete: if isAdmin();
      allow list: if isAdmin();
    }

    match /messages/{messageId} {
      allow read, write: if isAdmin();
      allow list: if isAdmin();
    }
    match /mail/{mailId} {
      allow create: if isAdmin();
      allow read: if isAdmin();
    }
  }
}
